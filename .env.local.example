# =============================================================================
# SanOS / DSA OS — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in the values from your Supabase
# project dashboard (Project Settings → API). NEVER commit `.env.local`.
# -----------------------------------------------------------------------------

# Public project URL — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose to the browser. RLS protects the data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Bypasses RLS. NEVER expose to the browser
# and NEVER prefix with NEXT_PUBLIC_. Used by admin client / seed scripts.
SUPABASE_SERVICE_ROLE_KEY=

# Project ref (the subdomain in your project URL, e.g. abcdefgh) — used by the
# Supabase CLI for `npm run db:types`. Optional when the CLI is already linked.
SUPABASE_PROJECT_ID=

# Public site URL — used to build the magic-link email redirect
# (`/auth/callback`). Set this in every deployed environment
# (e.g. https://your-app.vercel.app); without it magic-link emails redirect
# to a relative path that resolves incorrectly outside the browser context.
NEXT_PUBLIC_SITE_URL=
